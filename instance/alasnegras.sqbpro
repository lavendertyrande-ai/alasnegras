CREATE TABLE evento_new (
    id INTEGER PRIMARY KEY,
    titulo VARCHAR(200) NOT NULL,
    contenido TEXT,
    fecha_inicio DATETIME NOT NULL,
    fecha_fin DATETIME NOT NULL,
    url_twitch VARCHAR, -- aquí ya es NULLABLE
    creado DATETIME,
    actualizado DATETIME
);

INSERT INTO evento_new (id, titulo, contenido, fecha_inicio, fecha_fin, url_twitch, creado, actualizado)
SELECT id, titulo, contenido, fecha_inicio, fecha_fin, url_twitch, creado, actualizado
FROM evento;

DROP TABLE evento;

ALTER TABLE evento_new RENAME TO evento;

PRAGMA foreign_keys=on;
</sql><current_tab id="0"/></tab_sql></sqlb_project>
